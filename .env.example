# Base URL da API do backend (Laravel /api/v1).
# Variaveis lidas pelo app PRECISAM ter o prefixo EXPO_PUBLIC_.
# Apos alterar este arquivo, reinicie o Metro com cache limpo:
#   npx expo start -c

# Producao (funciona direto no celular fisico via Expo Go):
# EXPO_PUBLIC_API_BASE_URL=https://animesbr.lat/api/v1

# --- Alternativas para desenvolvimento local (Docker) ---
# Emulador Android (AVD):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000/api/v1
#
# Celular fisico na mesma Wi-Fi (troque pelo IP da sua maquina na LAN):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:8000/api/v1
#
# Simulador iOS / navegador (web):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
